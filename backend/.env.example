# ============================================================================
# CRITICAL SECURITY SETTINGS - MUST BE CONFIGURED IN PRODUCTION
# ============================================================================

# Debug mode (MUST be false in production)
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-generated-secret-key-here

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Use PostgreSQL in production (not SQLite)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/accredit

# ============================================================================
# FRONTEND & BACKEND URLs
# ============================================================================

FRONTEND_URL=https://accredit.vip
BACKEND_URL=https://api.accredit.vip

# ============================================================================
# PAYMENT PROCESSING - Paystack (Primary)
# ============================================================================

PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# ============================================================================
# PAYMENT PROCESSING - Flutterwave (Fallback)
# ============================================================================

FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key

# ============================================================================
# EMAIL SERVICES
# ============================================================================

# Primary: SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=Accredit.vip <noreply@accredit.vip>

# Fallback: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Fallback: Resend
RESEND_API_KEY=re_your_resend_api_key

# Email sender
EMAIL_FROM=Accredit.vip <noreply@accredit.vip>

# ============================================================================
# SMS SERVICES
# ============================================================================

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+1234567890

# WhatsApp Cloud API
WHATSAPP_CLOUD_TOKEN=your_whatsapp_cloud_token
WHATSAPP_CLOUD_PHONE_ID=your_phone_id

# Africa's Talking (SMS)
AFRICASTALKING_API_KEY=your_at_api_key
AFRICASTALKING_USERNAME=your_at_username

# Termii (SMS alternative)
TERMII_API_KEY=your_termii_api_key

# ============================================================================
# STORAGE & CDN
# ============================================================================

STORAGE_ENDPOINT=https://s3.your-region.amazonaws.com
STORAGE_BUCKET=accredit-uploads
STORAGE_KEY=your_storage_access_key
STORAGE_SECRET=your_storage_secret_key

# ============================================================================
# AI SERVICES
# ============================================================================

OPENAI_API_KEY=sk-your_openai_api_key

# ============================================================================
# SOCIAL AUTHENTICATION
# ============================================================================

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret

APPLE_CLIENT_ID=your_apple_client_id
APPLE_CLIENT_SECRET=your_apple_client_secret

# ============================================================================
# CACHE & MESSAGING
# ============================================================================

REDIS_URL=redis://localhost:6379/0

# ============================================================================
# BUSINESS CONFIGURATION
# ============================================================================

PLATFORM_FEE_PERCENT=5.0
VAT_PERCENT=2.5

# ============================================================================
# NOTES FOR SECURITY
# ============================================================================
# 1. NEVER commit .env file to git
# 2. NEVER share these values with anyone
# 3. Rotate keys regularly (every 90 days recommended)
# 4. Use strong passwords (minimum 16 characters)
# 5. For production, use a secrets management service:
#    - AWS Secrets Manager
#    - Azure Key Vault
#    - HashiCorp Vault
#    - Google Cloud Secret Manager
# 6. Enable MFA on all service accounts
# 7. Log all access to secrets
